# Jira Cloud — copy to .env and fill in (do NOT commit .env)

# Base URL of your instance, e.g. https://yourcompany.atlassian.net
JIRA_BASE_URL=

# Email of the account that generated the token
JIRA_EMAIL=

# API token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=

# (Optional) Default project for the tools that accept `projectKey` and you omit it.
# If not set, those tools will require an explicit `projectKey`.
JIRA_PROJECT_KEY=

# (Optional) Default assignees "of interest". Emails or accountIds
# separated by commas.
JIRA_DEFAULT_ASSIGNEES=

# --- Transport selection ---------------------------------------------------
# "stdio" (default): local, single user, credentials from the vars above.
# "http": multi-user server; per-request credentials come from HTTP headers
#         (X-Jira-Base-Url / X-Jira-Email / X-Jira-Token) and the JIRA_* vars
#         above are IGNORED. See README "Deploying on Debian".
MCP_TRANSPORT=stdio

# (http only) Interface/port to bind. Bind to an internal IP the proxy reaches;
# never expose without a firewall. Defaults: 127.0.0.1 / 3000.
HTTP_HOST=127.0.0.1
HTTP_PORT=3000
