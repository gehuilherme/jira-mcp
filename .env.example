# Jira Cloud — copie para .env e preencha (NÃO comitar o .env)

# URL base da sua instância, ex: https://suaempresa.atlassian.net
JIRA_BASE_URL=

# E-mail da conta que gerou o token
JIRA_EMAIL=

# API token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=

# (Opcional) Projeto default para as tools que aceitam `projectKey` e você omite.
# Se não definir, essas tools passam a exigir `projectKey` explícito.
JIRA_PROJECT_KEY=

# (Opcional) Responsáveis "de interesse" default. E-mails ou accountIds
# separados por vírgula.
JIRA_DEFAULT_ASSIGNEES=
